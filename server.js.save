const path = require("path");
const express = require("express");
const app = express();

// Serve frontend
app.use(express.static(path.join(__dirname, "dist"))); // or "public"

// For SPA routing (React/Vite)
app.get("*", (req, res) => {
  res.sendFile(path.join(__dirname, "dist", "index.html"));
});
